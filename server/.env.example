# ─────────────────────────────────────────────────────────────
# Inventory Tracker — Backend Environment Configuration
# Copy this file to ".env" and fill in real values.
# NEVER commit your real .env file to version control.
# ─────────────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=4000

# Comma-separated list of allowed front-end origins for CORS.
# In production set this to your real domain, e.g. https://app.yourstore.com
CLIENT_ORIGIN=http://localhost:5173

# ── Security ──────────────────────────────────────────────────
# Secret used to sign JSON Web Tokens. Use a long random string.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_secret
# How long a login session token stays valid.
JWT_EXPIRES_IN=7d

# Default 6-digit owner PIN assigned to every NEW account when it is created.
# Each owner can change their own PIN later from the Owner Portal → Settings.
DEFAULT_OWNER_PIN=123456

# ── Database ──────────────────────────────────────────────────
# The app uses libSQL (SQLite-compatible).
#
# LOCAL DEVELOPMENT: leave TURSO_* blank and it stores data in a local SQLite
# file at DATABASE_PATH — zero setup required.
DATABASE_PATH=./data/inventory.sqlite
#
# PRODUCTION: use a free, durable Turso database so data survives restarts and
# redeploys (required when NODE_ENV=production). Create one at https://turso.tech
# then paste the values below:
#   turso db create scan-safe
#   turso db show scan-safe --url           ->  TURSO_DATABASE_URL
#   turso db tokens create scan-safe        ->  TURSO_AUTH_TOKEN
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ── Email notifications (SMTP) ────────────────────────────────
# Used to email the store owner whenever a worker scans/checks out an item.
# If these are left blank, emails are logged to the console instead of being sent
# (handy for local development without an SMTP account).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# The "from" address that notification emails are sent as.
MAIL_FROM="Inventory Tracker <no-reply@yourstore.com>"

# Note: each new account's notification address defaults to the email it
# registered with. Owners can change it anytime in Owner Portal → Settings.
